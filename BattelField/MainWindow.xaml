<Window x:Class="BattelField.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Battleship: SOLID Commander" Height="720" Width="600" 
        Background="#1B1E23" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="GridButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="#2C3E50" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="1.0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="BATTLESHIP COMMAND" Foreground="#ECF0F1" 
                       FontSize="26" FontWeight="ExtraBold" HorizontalAlignment="Center"/>

            <UniformGrid Columns="3" Margin="0,8,0,0" HorizontalAlignment="Center" Width="520">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="SHOTS" Foreground="#BDC3C7" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ShotCount}" Foreground="#F1C40F" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="BEST SCORE" Foreground="#BDC3C7" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding BestScore}" Foreground="#2ECC71" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="TIMER" Foreground="#BDC3C7" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TimeLeft}" Foreground="#E67E22" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </UniformGrid>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,10">
            <Button Content="One Player" Width="110" Command="{Binding StartSinglePlayerCommand}" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Timer (sec, max 240):" Foreground="White" VerticalAlignment="Center" Margin="8,0,6,0"/>
                <TextBox Width="70" Text="{Binding RequestedTimerSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </StackPanel>

        <!-- Name entry and start two player -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,46,0,0">
            <TextBox x:Name="P1NameBox" Width="160" Margin="2" ToolTip="Player 1 name" />
            <TextBox x:Name="P2NameBox" Width="160" Margin="2" ToolTip="Player 2 name" />
            <Button Content="Start Two Player" Width="140" Margin="2" Click="StartTwo_Click"/>
        </StackPanel>

        <Viewbox Grid.Row="2">
            <ItemsControl ItemsSource="{Binding Grid}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="10" Columns="10"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="38" Height="38" Margin="1"
                                Style="{StaticResource GridButtonStyle}"
                                Background="{Binding StatusColor}"
                                Command="{Binding DataContext.FireCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Viewbox>

        <StackPanel Grid.Row="3" Margin="0,12,0,0" HorizontalAlignment="Center">
            <Border Background="#2C3E50" CornerRadius="5" Padding="10" Width="520">
                <TextBlock Text="{Binding StatusText}" Foreground="White" 
                           FontSize="14" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Set (Done Placement)" Width="160" Height="36" Command="{Binding ConfirmSetupCommand}" />
                <Button Content="Restart" Width="110" Height="36" Click="Restart_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Rectangle Width="12" Height="12" Fill="#34495E" Margin="5,0"/>
                <TextBlock Text="Unknown" Foreground="#7F8C8D" FontSize="10" Margin="4,0"/>
                <Rectangle Width="12" Height="12" Fill="#3498DB" Margin="15,0,5,0"/>
                <TextBlock Text="Miss" Foreground="#7F8C8D" FontSize="10"/>
                <Rectangle Width="12" Height="12" Fill="#E74C3C" Margin="15,0,5,0"/>
                <TextBlock Text="Hit" Foreground="#7F8C8D" FontSize="10"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>